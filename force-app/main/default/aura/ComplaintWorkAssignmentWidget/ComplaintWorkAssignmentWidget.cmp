                                    <div>State</div>
                                </th>
                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                                    <div>Country</div>
                                </th>
                                
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.custs}" var="cust">
                                <tr>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="{!cust.Name}"
                                        title="{!cust.Name}"
                                        
                                        >
                                        {!cust.Name}</td
                                        >
                                  <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="City"
                                        title="City"
                                        >
                                       
                                        <aura:if isTrue="{!cust. PersonMailingCity != null}">
                                             {!cust. PersonMailingCity}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                        
                                    </td > 
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="State"
                                        title="State" 
                                        >
                                         <aura:if isTrue="{!cust.PersonMailingState != null}">
                                             {!cust.PersonMailingState}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                       
                                    </td>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="Email"
                                        title="Email" 
                                        >
                                        <aura:if isTrue="{!cust.PersonMailingCountry != null}">
                                            {!cust.PersonMailingCountry}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                        
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table>
                    
                    <table
                           class="slds-table slds-table--bordered slds-table--cell-buffer slds-max-medium-table--stacked-vertical slds-border_left slds-border_right" onclick="{! c.openModel }">
                        
                        <thead>
                            <tr >
                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Account Number">
                                    <div>Home Phone</div>
                                </th>
                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Primary Borrower Name">
                                    <div>Mobile Phone</div>
                                </th>
                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                                    <div>Address Type</div>
                                </th>
                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                                    <div>Work Phone</div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.custs}" var="cust">
                                <tr>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="{!cust.PersonHomePhone}"
                                        title="{!cust.PersonHomePhone}"
                                        >
                                        <aura:if isTrue="{!cust.PersonHomePhone != null}">
                                            {!cust.PersonHomePhone}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                       </td>
                                        
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="Mobile Phone"
                                        title="Mobile Phone"
                                        >
                                         <aura:if isTrue="{!cust.PersonMobilePhone != null}">
                                             {!cust.PersonMobilePhone}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                        
                                    </td>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="Address Type"
                                        title="Address Type" 
                                        >
                                        <aura:if isTrue="{!cust.Address_Type__pc != null}">
                                              {!cust.Address_Type__pc}
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                       
                                    </td>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="Work Phone"
                                        title="Work Phone" 
                                        >
                                        <aura:if isTrue="{!cust.Work_Phone__pc != null}">
                                               {!cust.Work_Phone__pc }
                                            <aura:set attribute="else">
                                                -
                                            </aura:set>
                                        </aura:if>
                                       
                                    </td>
                                </tr>
                            </aura:iteration>
                        </tbody>
                    </table> 
                    
               </div>
                <!--Modal/Popup Box Footer Starts here-->
                <footer class="slds-modal__footer">                       
                    <lightning:button variant="neutral"
                                      label="OK"
                                      title="OK"
                                      onclick="{! c.closeModel }"/>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </aura:if>
</aura:component>