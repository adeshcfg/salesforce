<!--<aura:component controller="ComplaintWorkAssignmentWidgetController" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" > -->
<aura:component controller="ComplaintWorkAssignmentWidgetController" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" access="global" >
    
    <!-- attributes -->
     <aura:attribute name="entityId" type="String" access="public" />
     <aura:attribute name="draftValues" type="Product__C[]" />
     <aura:attribute name="custs" type="Account[]" /> 
     <aura:attribute name="isModalOpen" type="boolean" default="false"/>
    
    <!-- Handler-->
    <aura:handler name="init" value="{!this }" action="{!c.doinit }" />
    <table
           class="slds-table slds-table--bordered slds-table--cell-buffer slds-max-medium-table--stacked-vertical slds-border_left slds-border_right " onclick="{! c.openModel }">
        
        <thead>
            <tr >
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Account Number">
                    <div>Account Number</div>
                </th>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Primary Borrower Name">
                    <div>Primary Borrower</div>
                </th>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                    <div>Co-Borrower</div>
                </th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration items="{!v.draftValues}" var="draftValue">
                
                <tr>
                    <td
                        class="slds-truncate slds-text-align_center "
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="{!draftValue.Name}"
                        title="{!draftValue.Name}">
                        
                        <aura:if isTrue="{!or(draftValue.Name != null , draftValue != null)}">
                         {!draftValue.Name}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                        
                    </td>
                        
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="Primary Borrower Name"
                        title="Primary Borrower Name"
                        >
                        
                        <aura:if isTrue="{!or(draftValue.First_Name__c != null ,draftValue.Last_Name__c != null , draftValue != null) }">
                        {!draftValue.First_Name__c}&nbsp;{!draftValue.Last_Name__c}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                    </td>
                    <td   
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;" 
                        data-label="Co-Borrower Name"
                        title="Co-Borrower Name" 
                        >
                        
                        <aura:if isTrue="{!or(draftValue.Codebtor_First_Name__c != null ,draftValue.Codebtor_Last_Name__c != null , draftValue != null)}">
                        {!draftValue.Codebtor_First_Name__c}&nbsp;{!draftValue.Codebtor_Last_Name__c}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                    </td>
                                         
                </tr>
            </aura:iteration>
        </tbody>
    </table>
        
    <table
           class="slds-table slds-table--bordered slds-table--cell-buffer slds-max-medium-table--stacked-vertical slds-border_left slds-border_right" onclick="{! c.openModel }">
        
        <thead>
            <tr >
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Account Number">
                    <div>Principle Bal.</div>
                </th>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Primary Borrower Name">
                    <div>Interest Rate</div>
                </th>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                    <div>Interest Amount</div>
                </th>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                    <div>Current Total Bal.</div>
                </th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration items="{!v.draftValues}" var="draftValue">
                <tr>
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; Currency; padding: 1% 1% 1%;"
                        data-label="{!draftValue.Current_Principal_Balance__c}"
                        title="{!draftValue.Current_Principal_Balance__c}"
                        >
                        
                        <aura:if isTrue="{!draftValue.Current_Principal_Balance__c != null}">
                       ${!draftValue.Current_Principal_Balance__c}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                        
                    </td>
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="Interest Rate"
                        title="Interest Rate"
                        >
                        <aura:if isTrue="{!draftValue.Interest_Rate__c != null}">
                        {!draftValue.Interest_Rate__c}%
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                       
                    </td>
                    <td 
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; currency; padding: 1% 1% 1%;"
                        currencyDisplayAs="symbol"
                        data-label="Intereset Ammount"
                        title="Intereset Ammount" 
                        >
                        <aura:if isTrue="{!draftValue.Current_Interest_Amount__c != null}">
                        $
                        <lightning:formattedNumber value='{!draftValue.Current_Interest_Amount__c}' maximumFractionDigits="2"/> 
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                        
                    </td>
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="Current Total Bal."
                        title="Current Total Bal." 
                        >
                         <aura:if isTrue="{!draftValue.Current_Balance__c != null}">
                        $
                        <lightning:formattedNumber value='{!draftValue.Current_Balance__c}' maximumFractionDigits="2"/>      
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                        
                    </td>
                </tr>
            </aura:iteration>
        </tbody>
    </table>
    
    <table
           class="slds-table slds-table--bordered slds-table--cell-buffer slds-max-medium-table--stacked-vertical slds-border_left slds-border_right" onclick="{! c.openModel }">    
        <thead>
            <tr>
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Account Number">
                    <div>Customer Name</div>
                </th>
                
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                    <div>City</div>
                </th>
                
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Primary Borrower Name">
                    <div>State</div>
                </th>
                
                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                    <div>Country</div>
                </th>
            </tr>
        </thead>
        <tbody>
            <aura:iteration items="{!v.custs}" var="cust">
                <tr>
                    <td
                        class="slds-truncate slds-text-align_center"
