                        data-label="{!cust.Name}"
                        title="{!cust.Name}"
                        
                        >
                         <aura:if isTrue="{!cust.Name != null}">
                          {!cust.Name}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                       </td>
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label=" City"
                        title=" City" 
                        >
                        <aura:if isTrue="{!cust.PersonMailingCity != null}">
                         {!cust.PersonMailingCity}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                        
                    </td>
                        
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="State"
                        title="State"
                        >
                        
                        <aura:if isTrue="{!cust.PersonMailingState != null}">
                         {!cust.PersonMailingState}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                       
                    </td>
                    
                    <td
                        class="slds-truncate slds-text-align_center"
                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                        data-label="Email"
                        title="Country" 
                        >
                         <aura:if isTrue="{!cust.PersonMailingCountry != null}">
                         {!cust.PersonMailingCountry}
                        <aura:set attribute="else">
      								-
                        </aura:set>
  						</aura:if>
                       
                    </td>
                    
                </tr>
            </aura:iteration>
        </tbody>
     </table> 
    <table
           class="slds-table slds-table--bordered slds-table--cell-buffer slds-max-medium-table--stacked-vertical slds-border_left slds-border_right" onclick="{! c.openModel }">
        
        <thead>
