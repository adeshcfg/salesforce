                                <th scope="col" class="nobordertop slds-text-align_center" style="word-wrap: break-word; padding: 1% 1% 1% 1%;" title="Co-Borrower Name">
                                    <div>Collection Sub Status</div>
                                </th>
                                
                            </tr>
                        </thead>
                        <tbody>
                            <aura:iteration items="{!v.draftValues}" var="draftValue">
                                <tr>
                                    <td
                                        class="slds-truncate slds-text-align_center"
                                        style="word-wrap: break-word; padding: 1% 1% 1%;"
                                        data-label="{!draftValue.Name}"
                                        title="{!draftValue.Name}"
                                        
                                        >
