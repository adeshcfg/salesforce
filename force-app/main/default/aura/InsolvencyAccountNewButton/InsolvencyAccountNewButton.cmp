<aura:component implements="forceCommunity:availableForAllPageTypes,lightning:isUrlAddressable" access="global">
    <aura:attribute name="insolvencyId" type="String" />
    <aura:attribute name="insolvencyRecord" type="Object" />
    <aura:attribute name="recordLoadError" type="String" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <force:recordData aura:id="recordLoader" recordId="{!v.insolvencyId}" fields="Debtor__c"
        recordUpdated="{!c.handleRecordChanged}" targetFields="{!v.insolvencyRecord}"
        targetError="{!v.recordLoadError}" />
</aura:component>