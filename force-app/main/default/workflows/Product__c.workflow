    <rules>
        <fullName>Collection DD11 NOPTP</fullName>
        <actions>
            <name>Blank_Workflow</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Collection_activity_completed</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Workflow_flag_reset</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Activity_DD11_VoiceMail1</name>
            <type>Task</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 AND 2 AND 3 AND 4 AND 5</booleanFilter>
        <criteriaItems>
            <field>Product__c.Current_Workflow__c</field>
            <operation>equals</operation>
            <value>Collection Process</value>
        </criteriaItems>
        <criteriaItems>
            <field>Product__c.Workflow_Rule_Name__c</field>
            <operation>equals</operation>
            <value>Collection DD11</value>
        </criteriaItems>
        <criteriaItems>
            <field>Product__c.RecordTypeId</field>
            <operation>notEqual</operation>
            <value>Distressed Account</value>
        </criteriaItems>
        <criteriaItems>
            <field>Product__c.Workflow_run_flag__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Product__c.Workflow_Run_Date__c</field>
            <operation>notEqual</operation>
            <value>TODAY</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
