        <formula>ISCHANGED(CCS_Stage__c) &amp;&amp;  ( ISPICKVAL(CCS_Stage__c, &apos;Completed / Paid in Full&apos;) ||  ISPICKVAL(CCS_Stage__c, &apos;Settled&apos;)) &amp;&amp; (NOT(ISPICKVAL( PRIORVALUE(CCS_Stage__c) , &apos;Completed / Paid in Full&apos;))  || NOT(ISPICKVAL( PRIORVALUE(CCS_Stage__c) , &apos;Settled&apos;)) ) &amp;&amp; ISBLANK( Closed_Date__c ) &amp;&amp;  Record_Type_Name__c !=&apos;Distressed_Account&apos;</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Update CCS Stage Last Changed field</fullName>
        <actions>
            <name>Update_CCS_Stage_Last_Changed_field</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND(ISCHANGED( CCS_Stage__c ), Record_Type_Name__c !=&apos;Distressed_Account&apos;)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Update Initial Current Balance</fullName>
        <actions>
            <name>Update_Initial_Current_Balance</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Product__c.Original_Balance__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
