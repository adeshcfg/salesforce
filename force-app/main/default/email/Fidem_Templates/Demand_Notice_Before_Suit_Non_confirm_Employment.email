<!DOCTYPE html>
<html>
<style>
body{
	font-family:Calibri, Arial;
	width: 100%;
	text-align: left;
    color:rgba(23, 29, 35, 0.74);
    margin: auto;
    padding: 20px
}
td{
    padding-left: 20px !important;
}
.tdText{
	padding-left: 20px;
}
ul.no_bullet {
list-style-type: none;
padding: 0;
margin: 0;
}
li.bullet{
    background: url('https://c.na55.content.force.com/servlet/servlet.ImageServer?id=015f1000002jPl1&oid=00Dj0000001ripe&lastMod=1496998397000') no-repeat  left top; 
    height: 54px;
    padding-left: 44px;
padding-top: 3px;
}
</style>
	<body>
<div style="text-align: right; padding-right:5px;">
<img src='https://c.na55.content.force.com/servlet/servlet.ImageServer?id=015f1000001YmRe&oid=00Dj0000001ripe&lastMod=1493805474000'/>
</div>
<br/>
