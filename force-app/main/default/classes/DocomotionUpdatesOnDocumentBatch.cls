global class DocomotionUpdatesOnDocumentBatch implements Database.Batchable<sObject> {

    
    global Database.QueryLocator start(Database.BatchableContext bc) {
        // collect the batches of records or objects to be passed to execute
        return Database.getQueryLocator(
        	'SELECT Id, subject, status, whatId, createdDate FROM Task WHERE CreatedDate=TODAY AND Status = \'Generated by Docomotion\' AND Subject LIKE \'%Docomotion\' ORDER BY CREATEDDATE DESC'
        );
    
    }
    global void execute(Database.BatchableContext bc, List<Task> listTask){ 
        List<ContentDocumentLink> ConDocLnk = new List<ContentDocumentLink>();
        List<ContentDocument> ConDoc = new List<ContentDocument>();
        Set<Id> ConDoctoUpdateIdSet = new Set<Id>();
        List<ContentDocument> ConDoctoUpdateList = new List<ContentDocument>();
        system.debug('listTask: '+listTask.size());
        for(Task taskObj : listTask){
            system.debug('taskid : '+taskObj.Id);
            ConDocLnk = new List<ContentDocumentLink>();
            ConDoc = new List<ContentDocument>();
            
            dateTime createdDateValueSub = taskObj.createdDate.addSeconds(-300);
            system.debug('Created Date : ' + createdDateValueSub);
            dateTime createdDateValueAdd = taskObj.createdDate.addSeconds(300);
            system.debug('Created Date : ' + createdDateValueAdd ); 
    
            ConDocLnk=[SELECT Id,LinkedEntityId,ContentDocumentId,Visibility, ShareType 
                       FROM ContentDocumentLink 
                       WHERE LinkedEntityId =: taskObj.whatid 
                       AND SystemModstamp <= :createdDateValueAdd and SystemModstamp > :createdDateValueSub]; 
            System.debug('ConDoc : ' + ConDoc.size());
            
            Set <Id> CDIdSet = new Set <Id> ();
            for (ContentDocumentLink nextCDL : ConDocLnk) {      
                nextCDL.Visibility='AllUsers'; 
                CDIdSet.add(nextCDL.ContentDocumentId); 
            }
            
            system.debug('CDIdList : ' + CDIdSet);
            system.debug('Created Date : ' + taskObj.createdDate);
            
            ConDoc = [SELECT Id, Title, FileType,Description,CreatedDate,LastModifiedDate 
                      FROM ContentDocument 
                      WHERE Id IN :CDIdSet
                      AND createdDate <= :createdDateValueAdd 
                      AND createdDate > :createdDateValueSub
                      AND Description = NULL
                      ORDER BY CreatedDate ASC];
            System.debug('ConDoc : ' + ConDoc);
            
            if(conDoc.size() > 0){
                ConDoc[0].Description = taskObj.subject.split('-')[0];
                system.debug('ConDoc Id' + ConDoc[0].Id);
                if(!ConDoctoUpdateIdSet.contains(ConDoc[0].Id)){
                	ConDoctoUpdateIdSet.add(ConDoc[0].Id);
                    ConDoctoUpdateList.add(ConDoc[0]);    
                }
                
            }
        }
        system.debug('ConDoctoUpdateSet: '+ConDoctoUpdateList);
        update ConDoctoUpdateList;
    }
    
