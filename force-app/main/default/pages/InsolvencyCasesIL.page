<apex:page standardController="Insolvency__c" extensions="InsolvencyCasesILCntrl">
    <apex:form id="Form">   
        
        <apex:pageBlock rendered="{!AND(createNewCase, !isCommunityUser)}">
            <apex:commandButton style="margin-left:30%;" value="New Assignment" id="newAssignment" onclick="window.open('{!newCaseLink}');" /> 
        </apex:pageBlock>
    
        <apex:pageBlock title="Insolvency Assignments">
            <apex:pageBlockTable value="{!insolvencyWrapperCases}"  var="insolvencyWrapperCase" columns="5">
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Subject</apex:outputLabel>
                   </apex:facet>
                   <apex:outputLink value="{!insolvencyWrapperCase.caseLink}" target="_blank">
                        <apex:outputText value="{!insolvencyWrapperCase.cse.Subject}" /> 
                    </apex:outputLink>
                </apex:column>   
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Estate ID</apex:outputLabel>
                   </apex:facet>
                   <apex:outputText value="{!insolvencyWrapperCase.cse.Estate_ID__c}" /> 
                </apex:column>  
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Status</apex:outputLabel>
                   </apex:facet>
                   <apex:outputText value="{!insolvencyWrapperCase.cse.Status}" /> 
                </apex:column>
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Assigned To</apex:outputLabel>
                   </apex:facet>
                   <apex:outputText value="{!insolvencyWrapperCase.cse.Assigned_To__r.name}" /> 
                </apex:column> 
                <apex:column >
                    <apex:facet name="header">
                        <apex:outputLabel >Date Opened</apex:outputLabel>
                    </apex:facet>
                    <apex:outputText value="{!insolvencyWrapperCase.dateOpened}"/>
                </apex:column>   
            </apex:pageBlockTable>      
        </apex:pageBlock>
        
        <apex:pageBlock title="Insolvency Account Assignments">
            <apex:pageBlockTable value="{!insolvencyAccountWrapperCases}"  var="insolvencyAccountWrapperCase" columns="5">
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Subject</apex:outputLabel>
                   </apex:facet>
                   <apex:outputLink value="{!insolvencyAccountWrapperCase.caseLink}" target="_blank">
                        <apex:outputText value="{!insolvencyAccountWrapperCase.cse.Subject}" /> 
                    </apex:outputLink>
                </apex:column> 
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Account Number</apex:outputLabel>
                   </apex:facet>                   
                   <apex:outputLink value="{!insolvencyAccountWrapperCase.insolvencyAccountLink}" target="_blank">
                        <apex:outputText value="{!insolvencyAccountWrapperCase.cse.Account_Number__c}" /> 
                    </apex:outputLink>
                </apex:column>    
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Status</apex:outputLabel>
                   </apex:facet>
                   <apex:outputText value="{!insolvencyAccountWrapperCase.cse.Status}" /> 
                </apex:column>     
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Assigned To</apex:outputLabel>
                   </apex:facet>
                   <apex:outputText value="{!insolvencyAccountWrapperCase.cse.Assigned_To__r.name}" /> 
                </apex:column>   
                <apex:column >
                   <apex:facet name="header">
                       <apex:outputLabel >Date Opened</apex:outputLabel>
                   </apex:facet>
                        <apex:outputText value="{!insolvencyAccountWrapperCase.dateOpened}" /> 
                </apex:column>                  
            </apex:pageBlockTable>      
        </apex:pageBlock>
  
  </apex:form>
</apex:page>