<apex:page controller="CommissionStatementController" renderAs="pdf" readOnly="true" showHeader="false" applyHtmlTag="false" standardStylesheets="false">
    <!--<apex:stylesheet value="{!$Resource.Commission_Statement_CSS}"/>-->
    <html>
        <head>
            <link
                  rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css"
                  integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh"
                  crossorigin="anonymous"
                  />
            <style>
                table,
                th,
                td,
                tr {
                border: 1px double #4080bf;
                border-collapse: collapse;
                font-weight:500;
                vertical-align: top;
                }
                
                #firstTable table,
                #firstTable th,
                #firstTable tr,
                #firstTable td {
                border: 1px double #4080bf;
                border-collapse: collapse;
                font-weight: 500;
                vertical-align: top;
                }
                
                #secondTable table,
                #secondTable td {
                border: 1px double black;
                border-collapse: collapse;
                font-weight: 500;
                font-size: x-small;
                vertical-align: top;
                text-align: center;
                }
                
                #secondTable th {
                border: 1px double black;
                border-collapse: collapse;
                font-weight: 500;
                font-size: x-small;
                vertical-align: top;
                text-align: center;
                background-color: #909397;
                }
                
                #thirdTable table,
                tr,
                td,
                th {
                border: 1px double black;
                }
                
                #thirdTable2 table,
                tr,
                td,
                th {
                border: 1px double black;
                }
                
                #fourthTable th {
                border: 1px double black;
                border-collapse: collapse;
                font-weight: 500;
                vertical-align: top;
                text-align: center;
                background-color: #4080bf;
                }
                
                #fourthTable table,
                tr,
                td {
                border: 1px double black;
                }
                
                pre {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji",
                "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
                font-size: 1rem;
                font-weight: 500;
                }
                .header *{
    float: right;}
                .header img:first-child {
     float: left;}
                .hioa {
    height: 60px;
    margin-right:1em;}
            </style>
        </head>
        <body>
            <div class="header">
               <img class="hioa" src="{!$Resource.Commission_Statement_Image}" width="150" height="80"/>
                <!--<apex:image url="{!$Resource.Commission_Statement_Image}" width="150" height="80"/> --> 
                <h1 class="lsb">Payable</h1>     
            </div>
            <div style="page-break-inside:avoid; page-break-after:always;">
                <div class="col-md-2"></div>
                <div id="firstTable" class="col-md-8" style="padding-top:82px">
                    <table style="width:100%">
                        <tr>
                            <th 
                                colspan="2"
                                style="text-align: center; color: white;"
                                bgcolor="#4080bf"
                                >
                                Payable From
                            </th>
                            <th 
                                colspan="2"
                                style="text-align: center; color: white"
                                bgcolor="#4080bf"
                                >
                                Details
                            </th>
                        </tr>
                        <tr>
                            <td colspan="2" rowspan="3" style="padding-left: 5px">Canaccede Attention: Canaccede Accounts Payable</td>
                            <td style="text-align:right;padding-right: 5px;" width="150px">Number:</td>
                            <td width="150px" style="padding-left: 5px">{!num}</td>
                        </tr>
                        <tr>
                            <td style="text-align:right;padding-right: 5px" width="150px">Date:</td>
                            <td width="150px" style="padding-left: 5px">{!docCreatDate}</td>
                        </tr>
                        <tr>
                            <td style="text-align:right;padding-right: 5px" width="150px">Agency Name:</td>
                            <td width="150px" style="padding-left: 5px">{!placeDetails.Agency_Name__c}</td>
                        </tr>
                        <tr>
                            <td colspan="4" style="height: 23px"></td>
                        </tr>
                        <tr>
                            <th
                                colspan="2"
                                style="text-align: center; color: white"
                                bgcolor="#4080bf"
                                >
                                Recipient
                            </th>
                            <th
                                colspan="2"
                                style="text-align: center; color: white"
                                bgcolor="#4080bf"
                                >
                                Totals
                            </th>
                        </tr>
                        <tr>
                            <td colspan="2" rowspan="4" style="padding-left: 5px">
                                <apex:outputpanel rendered="{!placeDetails.Agency_Name__c != null}" style="margin-right:5px;">{!placeDetails.Agency_Name__c}</apex:outputpanel><apex:outputpanel rendered="{!placeDetails.Agency_Phone_Number__c != null}">{!placeDetails.Agency_Phone_Number__c}<br/></apex:outputpanel>
                                <apex:outputpanel rendered="{!placeDetails.Agency_Street1__c != null}">{!placeDetails.Agency_Street1__c}<br/></apex:outputpanel>
                                <apex:outputpanel rendered="{!placeDetails.Agency_Street2__c != null}">{!placeDetails.Agency_Street2__c}<br/></apex:outputpanel>
                                {!placeDetails.Agency_City__c} {!placeDetails.Agency_State__c} {!placeDetails.Agency_Zip_Code__c}<br/>
                                HST/GST Registration Number: {!placeDetails.HST_GST_Registration_Number__c}
                            </td>
                            <td style="text-align:right;padding-right: 5px" width="150px">Amount:</td>
                            <td width="150px" style="padding-left: 5px"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    								<apex:param value="{!totalAmount}"/>
								</apex:outputText></td>
                        </tr>
                        <tr>
                            <td rowspan="3" style="text-align:right;padding-right: 5px" width="150px">Date Due:</td>
                            <td rowspan="3" width="150px" style="padding-left: 5px">{!docCreatDate}</td>
                        </tr>
                        <tr></tr>
                        <tr></tr>
                        <tr>
                            <th
                                colspan="4"
                                style="text-align: center; color: white"
                                bgcolor="#4080bf"
                                >
                                Terms
                            </th>
                        </tr>
                        <tr>
                            <td colspan="4" style="padding-left: 5px">Not Applicable</td>
                        </tr>
                        <tr>
                            <td colspan="4" style="height: 23px"></td>
                        </tr>
                        <tr>
                            <th
                                colspan="4"
                                style="text-align: center; color: white"
                                bgcolor="#4080bf"
                                >
                                Details
                            </th>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center">Description</td>
                            <td colspan="2" style="text-align: center" width="150px">Amount</td>
                        </tr>
                        <tr>
                            <td colspan="2" style="padding-left: 5px">Placement {!placeDetails.Name} Statement for {!monthName} {!year}</td>
                            <td colspan="2" style="text-align: right" width="150px"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    								<apex:param value="{!totalAmount}"/>
								</apex:outputText></td>
                        </tr>
                        <apex:repeat value="{!Summaries}" var="summary">
                            <tr>
                                <td colspan="4" style="padding-left: 5px">
                                  <!--  <pre style="padding-left: 5px">-->
{!summary.province}:
<table style="border: none;margin-left:50px">
<tr style="border: none;">
<th style="border: none;"></th>
<th style="border: none;"></th>
</tr>
<tr style="border: none;">
<td style="border: none">Direct Payments:<br/>
	Payment Update Reconciliation:<br/>
	<apex:outputpanel rendered="{!summary.gst != 0.00}">GST:<br/></apex:outputpanel>
	<apex:outputpanel rendered="{!summary.pst != 0.00}">PST:<br/></apex:outputpanel>
	<apex:outputpanel rendered="{!summary.hst != 0.00}">HST:<br/></apex:outputpanel>
	<apex:outputpanel rendered="{!summary.gstpst != 0.00}">GST+PST:<br/></apex:outputpanel>
	<apex:outputpanel rendered="{!summary.gstqst != 0.00}">GST+QST:<br/></apex:outputpanel>
	Total Amount:
</td>
<td style="border: none;padding-left:20px">	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.directPayment}"/>
	</apex:outputText><br/>
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.paymentUpdateRe}"/>
	</apex:outputText><br/>
    <apex:outputpanel rendered="{!summary.gst != 0.00}">
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.gst}"/>
        </apex:outputText><br/></apex:outputpanel>
    <apex:outputpanel rendered="{!summary.pst != 0.00}">
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.pst}"/>
        </apex:outputText><br/></apex:outputpanel>
    <apex:outputpanel rendered="{!summary.hst != 0.00}">
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.hst}"/>
        </apex:outputText><br/></apex:outputpanel>
    <apex:outputpanel rendered="{!summary.gstpst != 0.00}">
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.gstpst}"/>
        </apex:outputText><br/></apex:outputpanel>
    <apex:outputpanel rendered="{!summary.gstqst != 0.00}">
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.gstqst}"/>
        </apex:outputText><br/></apex:outputpanel>
	<apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!summary.total}"/>
	</apex:outputText>
</td>
</tr>					                                                
</table>

                                    
                                    
                                </td>
                            </tr>
                        </apex:repeat>
                    </table>
                </div>
                <div class="col-md-2"></div>
            </div>
            <!-- <div class="row" style="height: 500px">
               <div></div> 
            </div>-->
            <div class="row">
                <div style="height: 50px; margin-left: 10px">
                    Placement Summary Statement {!num}
                </div>
            </div>  
            <div class="row" style="page-break-inside:avoid; page-break-after:auto;">
                <!--<div class="col-md-1"></div>-->
                <div class="col-md-10" id="secondTable">
                    <table style="width: 100%">
                        <tr>
                            <th>Placement</th>
                            <th>Pool</th>
                            <th>Data ID</th>
                            <th>Type</th>
                            <th>Payment Created Date</th>
                            <th>Gross Amount</th>
                            <th>Reimbursement</th>
                            <th>Rate</th>
                            <th>Contingency</th>
                            <th>Province</th>
                            <th>Tax Amount</th>
                            <th>Retained</th>
                            <th>Reconciliation</th>
                            <th>Amount Due</th>
                        </tr>
                        <tr>
                            <th
                                colspan="13"
                                style="background-color: #4080bf; color: white; text-align: left;padding-left: 5px"
                                >
                                Pool Bonus Summary
                            </th>
                            <th style="background-color: #4080bf; color: white"></th>
                        </tr>
                        <tr>
                            <td colspan="13" style="text-align: left;padding-left: 5px">
                                No pool bonuses are available on this statement
                            </td>
                            <td></td>
                        </tr>
                        <tr style="height: 20px">
                            <td colspan="13" style="text-align: left"></td>
                            <td></td>
                        </tr>
                        <tr>
                            <th
                                colspan="13"
                                style="background-color: #4080bf; color: white; text-align: left;padding-left: 5px"
                                >
                                Direct Payments
                            </th>
                            <th style="background-color: #4080bf; color: white"></th>
                        </tr>
                        <apex:repeat value="{!prodPayList1}" var="key">
                            <apex:repeat value="{!key}" var="record">
                            <tr>
                                <td><apex:outputField value="{!record.Payment_Provided_Agency__r.Name}" /></td>
                                <td><apex:outputField value="{!record.CCS_Account__r.Pool_Name__r.Name}" /></td>
                                <td><apex:outputField value="{!record.CCS_Account__r.Name}" /><apex:outputpanel rendered="{!record.Legal_Product_Identifier__c == 'Yes'}">(L)</apex:outputpanel></td>
                                <td><apex:outputField value="{!record.Payment_Type__c}" /></td>
                                <td><apex:outputField value="{!record.Payment_Created__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Gross_Payment_Amount__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Pay_Reimburse__c}" /></td>
                                <td><apex:outputField value="{!record.Commission_Rate_for_Payment__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Pay_Due__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Tax_Province__c}" />(<apex:outputField value="{!record.Tax_Province_Rate__c}" />)</td>
                                <td style="text-align: right"><apex:outputField value="{!record.Tax_Amount__c}" /></td>
                                <td style="text-align: right">-</td>
                                <td style="text-align: right">-</td>
                                <td style="text-align: right"><apex:outputField value="{!record.Amount_Due__c}" /></td>
                            </tr>
                               
                                </apex:repeat>
                        </apex:repeat>
                          <tr>
                            <td colspan="5" style="background-color: #4080bf; color: white; text-align: left;padding-left: 5px">Direct Pay Totals</td>
                               <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdDirectPayment['payAmount']}"/>                                 
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdDirectPayment['payReimburse']}"/>
    </apex:outputText>
                             </td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdDirectPayment['PayDueAmount']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdDirectPayment['taxAmount']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!retainedAmountForDirectPayment}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdDirectPayment['amountDue']}"/>
	</apex:outputText></td>
                        </tr>
                        <tr style="height: 15px">
                            <td colspan="13"></td>
                              <td colspan="1"></td>
                        </tr>
                        <tr>
                            <td colspan="13" style="background-color: #4080bf; color: white; text-align: left;padding-left: 5px">Payment Update Detail</td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                        </tr>
                         <apex:repeat value="{!prodPayUpdate}" var="key">
                            <apex:repeat value="{!key}" var="record" >
                            <tr>
                                <td><apex:outputField value="{!record.Payment_Provided_Agency__r.Name}" /></td>
                                <td><apex:outputField value="{!record.CCS_Account__r.Pool_Name__r.Name}" /></td>
                                <td><apex:outputField value="{!record.CCS_Account__r.Name}" /><apex:outputpanel rendered="{!record.Legal_Product_Identifier__c == 'Yes'}">(L)</apex:outputpanel></td>
                                <td><apex:outputField value="{!record.Payment_Type__c}" /></td>
                                <td><apex:outputField value="{!record.Payment_Created__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Gross_Payment_Amount__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Pay_Reimburse__c}" /></td>
                                <td><apex:outputField value="{!record.Commission_Rate_for_Payment__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Pay_Due__c}" /></td>
                                <td style="text-align: right"><apex:outputField value="{!record.Tax_Province__c}" />(<apex:outputField value="{!record.Tax_Province_Rate__c}" />)</td>
                                <td style="text-align: right"><apex:outputField value="{!record.Tax_Amount__c}" /></td>
                                <td style="text-align: right">-</td>
                                <td style="text-align: right">-</td>
                                <td style="text-align: right"><apex:outputField value="{!record.Amount_Due__c}" /></td>
                            </tr>
                                </apex:repeat>
                        </apex:repeat>
                        <tr style="height: 15px">
                           <td colspan="5" style="background-color: #4080bf; color: white; text-align: left;padding-left: 5px"></td>
                               <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdPayUpdate['payAmount']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdPayUpdate['payReimburse']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdPayUpdate['PayDueAmount']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
     <apex:param value="{!aggProdPayUpdate['taxAmount']}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!retainedAmountFoPaymentUpdate}"/>
	</apex:outputText></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"><apex:outputText value="${0, number, ###,###,###,##0.00}">
    <apex:param value="{!aggProdPayUpdate['amountDue']}"/>
	</apex:outputText></td>
                        </tr>
                        <tr style="height: 15px">
                            <td colspan="13"></td>
                              <td colspan="1"></td>
                        </tr>
                        <tr style="height: 15px">
                            <td colspan="13" style="background-color: #4080bf; color: white"></td>
                              <td colspan="1" style="background-color: #4080bf; color: white"></td>
                        </tr>
                        <div></div>
                    </table>
                    <p style="font-size:8px;">Note: **L stands for Legal Account(s)</p>
                </div>
                <div class="col-md-1"></div>
            </div>
        </body>
    </html>
</apex:page>