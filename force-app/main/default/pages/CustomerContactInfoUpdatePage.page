<apex:page controller="DisplayCustomerContInfoStagingController" showheader="true" standardStyleSheets="false" 
           sidebar="false" cache="false" docType="html-5.0" >
    <apex:form id="form">
        <apex:slds />
        <style type="text/css">
            table{
            width: 100%;
            background-color: white;
            border:1px solid black;
            padding: 5px;
            }
            
            tr{
            text-align: left;
            padding: 5px;
            }
            
            td{
            padding: 0 15px 0 15px!important;
            }
            
            th{
            padding: 0 15px 0 15px!important;
            text-align:center;
            vertical-align:top;
            }
            .first h3{
            background-color: #0CA1CF;
            padding: 5px 3px;
            }
            
            .page_navigation{
            font-family: tahoma;
            font-size: 11px;
           float: left;
            
            }
            
            .page_navigation a{
            text-decoration: none;
            padding: 3px 5px;
            margin: 0 2px;
            background-color: white;
            color: #28ADD9;
            display: block;
            float: left;
            text-align: center;
            border-color:#28ADD9;
            }
            
            .page_navigation .active_page{
            background-color: white;
            color: black;
            }
            
            .demo2{
            margin: 10px 5px;
            background-color: #00064F;
            overflow:auto;
            text-align: center
            }
            
            .title{
            font-family: Georgia;
            font-size: 36px;
            font-style: italic;
            color: white;
            padding: 10px;
            }
            
            .head{
            font-family: Tahoma;
            font-size:20px;
            color: orange;
            padding: 5px;
            overflow: auto;
            
            }
            thead{
            border: 1px solid;
            text-align:center;
            }
            .th{
            text-align:center;
            }
            .body {
            
           
            }
            
            .content {
            width: 90%;
            margin: 0px auto;
            overflow: auto;
            }
            
            .item{
            color: black;
            font-family: Georgia;
            font-size: 16px;
            padding: 10px;
            display: block;
            
            }
            
            .block{
            display:block;
            }
            
            .panel {
            width: 40%;
            float: left;
            padding: 0 30px;
            
            }
            
            .demo2 .page_navigation a{
            background-color: orange;
            color: black;
            }
            
            .demo2 .page_navigation .active_page{
            background-color: transparent;
            color: white;
            }
            
            #theid{
            align-content: center;
            text-align: center;
            margin-left: 32%;
            margin-top: 3%;
            }       
            
        </style>
        <apex:includeScript value="{!$Resource.EFTJQuery}"/>     
        <apex:includeScript value="{!$Resource.Paginate}"/>       
        <script type="text/javascript">
        $.noConflict();
        
        jQuery(document).ready(function($){
            $(esc(pbsId)).pajinate({
                item_container_id : esc(accountTableBodyId),
                items_per_page : 25
            });
            
            $('.demo2').pajinate();
        }); 
        
        function esc(myid) {
            return '#' + myid.replace(/(:|\.)/g,'\\\\$1');
        }
        
         function selectAllCheckboxes(obj,receivedInputID){
            var inputCheckBox = document.getElementsByTagName("input");                
            for(var i=0; i<inputCheckBox.length; i++){ 
                console.log(inputCheckBox[i].disabled);
                if(inputCheckBox[i].id.indexOf(receivedInputID)!=-1 && inputCheckBox[i].disabled == false) {                                    
                    inputCheckBox[i].checked = obj.checked;
                }
            }
        }
        
        </script>
        
        <apex:pageMessages ></apex:pageMessages>
        <apex:define name="content"> 
            
            
            <apex:outputPanel rendered="{!!listCustomerContInfoStagingWrapper.Empty}" id="panel2">
                <apex:outputPanel >
                    <div style = "font-weight:bold;font-size:large">
                        Customer Contact Information Records to verify
                    </div>
                    <apex:outputPanel title="" id="pbs" >
                        <div class="page_navigation"></div>
                        <script> 
                        var accountTableId = '{!$Component.accountTable}'; 
                        var accountTableBodyId = accountTableId + ':tb';
                        var pbsId = '{!$Component.pbs}';
                        </script>
                        
                        <apex:datatable value="{!listCustomerContInfoStagingWrapper}" var="account" id="accountTable">
                            <apex:column headerValue="Action" >
                                <apex:facet name="header">
                                    <apex:inputCheckbox onclick="selectAllCheckboxes(this,'inputId')">
                                        <!--<apex:actionSupport event="onchange" />-->
                                    </apex:inputCheckbox>
                                </apex:facet>
                                <apex:inputCheckbox id="inputId" value="{!account.selected}" disabled="{!account.disabled}">
                                    <!--<apex:actionSupport event="onchange" />-->
                                </apex:inputCheckbox>
                            </apex:column>
                            
                            <apex:column >
                                <apex:facet name="header"><apex:outputText value="Product" /></apex:facet>
                                <apex:outputLink value="/{!account.custStaging.Product_ID__c}" target="_blank">
                               {!account.custStaging.ProdID__c}
                                </apex:outputLink>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Email <br/> Address</apex:facet>
                                <apex:outputField value="{!account.custStaging.Email_Address__c}"/>
                            </apex:column>            
                            <apex:column >                    
                                <apex:facet name="header"> Address <br/> Line 1</apex:facet>
                                <apex:outputText value="{!account.custStaging.Address_Line1__c}"/>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Address <br/> Line 2</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Address_Line2__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> City</apex:facet>
                                <apex:outputfield value="{!account.custStaging.City__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Province</apex:facet>
                                <apex:outputfield value="{!account.custStaging.State__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Postal <br/> Code</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Postal_Code__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Country</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Country__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Home <br/> Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Home_Phone__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Work <br/> Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Work_Phone__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Other <br/> Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Cell_Phone__c}"></apex:outputfield>
                            </apex:column>
                            
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Email</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Email__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >                    
                                <apex:facet name="header"> Co-Borrower <br/> Address Line1</apex:facet>
                                <apex:outputText value="{!account.custStaging.Coborrower_Address1__c}"/>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Addres Line2</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Address2__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> City</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_City__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Province</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_State__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Postal code</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Postal_Code__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Country</apex:facet> 
                                <apex:outputfield value="{!account.custStaging.Coborrower_Country__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Home Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Home_Phone__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Work Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Work_Phone__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Co-Borrower <br/> Other Phone</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Coborrower_Cell_Phone__c}"></apex:outputfield>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Comment</apex:facet>
                                <apex:outputText value="{!account.custStaging.Comment__c}" escape="false"></apex:outputText>
                            </apex:column>
                            <apex:column style="width:14%;vertical-align:baseline">
                                <apex:facet name="header">Expected Result</apex:facet>
                                <apex:outputText value="{!account.custStaging.Expected_Value__c}" escape="false"></apex:outputText>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"> Status</apex:facet>
                                <apex:outputfield value="{!account.custStaging.Status__c}"></apex:outputfield>
                            </apex:column>
                            
                        </apex:datatable>
                        <apex:actionStatus id="status">
                            <apex:facet name="start">
                                <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.75; z-index: 1000; background-color: black;">
                                    &nbsp;
                                </div>
                                <div style="position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 30% 50%">
                                    <img src="http://upload.wikimedia.org/wikipedia/commons/e/ed/Cursor_Windows_Vista.gif" />
                                </div>
                            </apex:facet>
                        </apex:actionStatus>
                        <apex:actionFunction action="{!Save}" name="InsertRecord_JS" Rerender="panel1, panel2, status, form"
                                             status="status" oncomplete="CallWebService_JS();"/>
                   <!--     <apex:actionFunction action="{!postDocumentAPI}" name="CallWebService_JS" status="status"
                                             reRender="panel1, panel2, status, form"/> -->
                        <div class="page_navigation"></div>
                        <div style = "Margin-left:35%;padding-top: 1%;">
                            <apex:commandButton onclick="InsertRecord_JS();return false;"
                                                value="Process Records" id="theButtonn" 
                                                styleclass="slds-button slds-button_neutral" 
                                                style="margin-left: 20%;"
                                                disabled="{!!showButton}"/>
                        </div>
                        
                    </apex:outputPanel>
                </apex:outputPanel>
            </apex:outputPanel> 
        </apex:define>
        <apex:outputPanel rendered="{!displayPanel}" id="panel1"> 
            Records Process Complete! <br/>
            Please check
            <apex:outputlink value="/{!workAssignmentId}"> Work Assignment </apex:outputlink>&nbsp;record
        </apex:outputPanel>
    </apex:form>
</apex:page>