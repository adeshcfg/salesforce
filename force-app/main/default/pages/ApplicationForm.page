                                <table id="cc_disclosure" class="responsive">
                                    <tbody>
                                        <tr>
                                            <th>Annual Interest Rate</th>
                                            <td>
                                                <p>
                                                    These interest rates are in effect the day your
                                                    account is activated.
                                                </p>
                                                <p>
                                                    <strong>Affirm Mastercard<sup>&#174;</sup> for HOMEOWNERS:</strong>
