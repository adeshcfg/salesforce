                                            <apex:selectOptions value="{!homeOwnerOptions}" />
                                        </apex:selectRadio>
                                        <div id="homeOwnerErrMsg" class="invalidFieldMsg hidden">
                                           Please specify if you are a Home Owner.
                                        </div>
                                    </td>
                                </table>    
                            </div> 
                            
                            <table id="prncTbl">
