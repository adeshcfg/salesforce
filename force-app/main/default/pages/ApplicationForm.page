                                        <apex:selectOptions value="{!LoanTypeOptions}" />
                                    </apex:selectRadio>
                                    <div id="loanTypeErrMsg" class="invalidFieldMsg hidden">Please
                                        select a Loan Type.</div></td>
                            </table>
                            
                            <div id="homeOwnerQuestion" class="hidden">
                                <table id="hoTbl">
