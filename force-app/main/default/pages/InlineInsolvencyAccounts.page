<apex:page standardController="Insolvency__c" extensions="InlineInsolvencyAccountsCntrl" id="page" showHeader="false" sidebar="false">
    
    <style>
        .headerRowlabel{
        border-width: 0 0 1px 1px;
        color: #4a4a56;
        font-size: .9em;
        font-weight: bold;
        padding: 5px 2px 4px 5px;
        }
        .individualPalette .accountBlock .secondaryPalette {
        border-color: #f8f8f8;
        }
        body{
        background-color: #f8f8f8;}
        .vfHelpText a            {position:relative;}
        .vfHelpText a span       {display: none;}
        .vfHelpText a:hover span {display: block;
        position:absolute;
        top:1.25em;
        padding:2px 5px;
        left:-15em; width:15em;
        z-index:100;
        border:1px solid orange;
        background-color:#FEFDB9;
        color:black;
        text-align:left;
        }
    </style>
    <script>
    function removeInsolvencyAccount(index){
        alert(index);
        removeInsolvencyAcc(index);
    }
    function changeRtype(ele){
        recordTypeSelected(ele.value);
        console.log(ele.value);
    }
    function closeWindow(){
        window.close();
    }
    </script>
    <!-- Displaying Insolvency information -->
    <apex:outputPanel >
        <apex:form >
            
             
            <apex:pageBlock tabStyle="Insolvency__c" id="pbDisplay" >
                <apex:pageBlockSection columns="2">
                    
                    <apex:outputField value="{!insolv.Name}"/>
                    
                    <apex:pageBlockSectionItem >
                        <apex:outputPanel >
                            {!$ObjectType.Insolvency__c.fields.Insolvency_Type__c.label}
                            <span class="vfHelpText">
                                <apex:outputLink value="javascript:return false;">
                                    <img src="/s.gif" alt="" class="helpOrb" />
                                    <span>{!$ObjectType.Insolvency__c.fields.Insolvency_Type__c.inlineHelpText}</span>
                                </apex:outputLink>
                            </span>
                        </apex:outputPanel>
                        {!insolv.Insolvency_Type__c}
                    </apex:pageBlockSectionItem>
                    
                    <apex:pageBlockSectionItem >
                        <apex:outputPanel >
                            {!$ObjectType.Insolvency__c.fields.Insolvency_Date__c.label}
                            <span class="vfHelpText">
                                <apex:outputLink value="javascript:return false;">
                                    <img src="/s.gif" alt="" class="helpOrb" />
                                    <span>{!$ObjectType.Insolvency__c.fields.Insolvency_Date__c.inlineHelpText}</span>
                                </apex:outputLink>
                            </span>
                        </apex:outputPanel>
                        <apex:outputField value="{!insolv.Insolvency_Date__c}"/>
                    </apex:pageBlockSectionItem>
                    
                    <apex:pageBlockSectionItem >
                        <apex:outputPanel >
                            {!$ObjectType.Insolvency__c.fields.Insolvency_Status__c.label}
                            <span class="vfHelpText">
                                <apex:outputLink value="javascript:return false;">
                                    <img src="/s.gif" alt="" class="helpOrb" />
                                    <span>{!$ObjectType.Insolvency__c.fields.Insolvency_Status__c.inlineHelpText}</span>
                                </apex:outputLink>
                            </span>
                        </apex:outputPanel>
                        <apex:outputField value="{!insolv.Insolvency_Status__c}"/>
                    </apex:pageBlockSectionItem>
                    
                    <apex:pageBlockSectionItem >
                        <apex:outputPanel >
                            {!$ObjectType.Insolvency__c.fields.Debtor__c.label}
                            <span class="vfHelpText">
                                <apex:outputLink value="javascript:return false;">
                                    <img src="/s.gif" alt="" class="helpOrb" />
                                    <span>{!$ObjectType.Insolvency__c.fields.Debtor__c.inlineHelpText}</span>
                                </apex:outputLink>
                            </span>
                        </apex:outputPanel>
                        <apex:outputField value="{!insolv.Debtor__c}"/>
                    </apex:pageBlockSectionItem>
                    
                    <apex:pageBlockSectionItem >
                        <apex:outputPanel >
                            {!$ObjectType.Insolvency__c.fields.Co_Debtor__c.label}
                            <span class="vfHelpText">
                                <apex:outputLink value="javascript:return false;">
                                    <img src="/s.gif" alt="" class="helpOrb" />
                                    <span>{!$ObjectType.Insolvency__c.fields.Co_Debtor__c.inlineHelpText}</span>
                                </apex:outputLink>
                            </span>
                        </apex:outputPanel>
                        <apex:outputField value="{!insolv.Co_Debtor__c}"/>
                    </apex:pageBlockSectionItem>
                    
                    
                </apex:pageBlockSection>
            </apex:pageBlock>
            
        </apex:form>
    </apex:outputPanel>
    <hr style="border-color: #236fbd;"/>
    <br/>
    
    <apex:form id="fm">
        <apex:actionStatus id="spinner">
            <apex:facet name="start">
                <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.25; z-index: 1000; background-color: black;">
                    &nbsp;
                </div>
                <div style="position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 12% 40%">
                    <div style="display: inline-block; padding: 2px; background-color: #fff; width: 125px;">
                        <img src="/img/loading.gif" style="float: left; margin: 8px;" />
                        <span style="display: inline-block; padding: 10px 0px;">Please Wait...</span>
                    </div>
                </div>
            </apex:facet>
        </apex:actionStatus>
        
        <!--
<apex:inputField value="{!insolvAccnt.recordtypeid}" onchange="changeRtype(this)"/>
-->
        <apex:ActionFunction name="recordTypeSelected" action="{!recordTypeSelected}" oncomplete="refresh();" status="spinner" immediate="true">
            <apex:param name="rType" 
                        value="" 
                        assignTo="{!rType}"/>
        </apex:ActionFunction>
        <apex:ActionFunction name="refresh" status="spinner" reRender="out" immediate="true"/>
        <br/>
        <apex:outputPanel id="out" style="overflow:scroll;height:520px;" layout="block">
         
            <apex:pageBlock tabStyle="Account" title="Add Insolvency Accounts" id="pgb"> 
                <apex:pageMessages id="errorMsg" escape="false"></apex:pageMessages>
               
                <apex:pageBlockButtons location="top">
                    <apex:commandButton value="Save" action="{!save}" reRender="pgb, errorMsg" status="spinner" rendered="{!wrapList.size > 0}"/>
                    <apex:commandButton value="Add New Insolvency Account" action="{!addMore}" status="spinner" reRender="pgb,pbDisplay" immediate="true"/>
                    
                    <apex:outputLabel >Select Bank Type:</apex:outputLabel>
                    
                    <apex:selectList value="{!rType}" required="true" size="1" multiselect="false" onchange="changeRtype(this)">                    
                        <apex:selectOptions value="{!insolvencyRtype}" />
                    </apex:selectList>
                </apex:pageBlockButtons>
                <apex:pageBlockTable value="{!wrapList}" var="wrap" id="pgbt" rendered="{!wrapList.size > 0}" columns="12" >
                    <apex:column headerValue="Bank Name" >
                        <apex:outputField value="{!wrap.insolvAcc.RecordTypeId}"/>
                    </apex:column>
                    
                    <apex:column headerValue="Account Number">
                        <apex:inputField value="{!wrap.insolvAcc.Name}" required="true"/>
                    </apex:column>
                    <apex:column headerValue="Product Type" id="prodType">
                        <apex:inputField value="{!wrap.insolvAcc.Account_Type__c}" required="true"/>
                    </apex:column>
                    <apex:column headerValue="Product Code">
                        <apex:inputField value="{!wrap.insolvAcc.Product_Code__c}"/>
                    </apex:column>
                    <apex:column headerValue="Claim Type" id="claimType">
                        <apex:inputField value="{!wrap.insolvAcc.Claim_Type__c}" required="true"/>
                    </apex:column>
                    
                    <!-- Optional fields -->
                    <apex:column headerValue="Security Type" id="secType">
                        <apex:inputField value="{!wrap.insolvAcc.Security_Type__c}"/>
                    </apex:column>
                    <apex:column headerValue="Security description">
                        <apex:inputField value="{!wrap.insolvAcc.Security_Description__c}"/>
                    </apex:column>
                    <apex:column headerValue="Duplicate reason" style="width:250px" id="dup">
                        <apex:inputField value="{!wrap.insolvAcc.Duplicate_Reasons_Picklist__c}"/>
                    </apex:column>
                    <!--<apex:column headerValue="Investment Group"  id="InvGroup">
                        <apex:inputField value="{!wrap.insolvAcc.Investment_Group__c}"/>
                    </apex:column>
                    <apex:column headerValue="Portfolio Group Name" id="portGroup">
                        <apex:inputField value="{!wrap.insolvAcc.Portfolio_Group_Name__c}" />
                    </apex:column>
                    <apex:column headerValue="Portfolio Name" id="portName">
                        <apex:inputField value="{!wrap.insolvAcc.Portfolio_Name_Lookup__c}"/>
                    </apex:column>-->
                    <apex:column >
                        <apex:commandlink rendered="{!wrap.insolvAcc.Id == NULL}" style="text-decoration: none;padding: 4px;" styleclass="btn" value="Remove" action="{!removeInsolvencyAccount}" reRender="pgb" immediate="true">
                            <apex:param name="aindex" assignTo="{!index}" value="{!wrap.key}"/>
                        </apex:commandlink>
                    </apex:column>
                </apex:pageBlockTable>
                <div style="text-align:center;">
                    <input style="margin-top: 10px;" type="button" class="btn" onclick="closeWindow();" value="Cancel"/>
                </div>
                <!--
<apex:outputPanel rendered="{!wrapList.size > 0}" id="bottomButtons">
<div style="text-align:center;">
<apex:commandButton value="Save" action="{!save}" reRender="pgb, errorMsg" status="spinner"/>
<apex:commandButton value="Add New Insolvency Account" action="{!addMore}" status="spinner" reRender="pgb" immediate="true"/>
</div>
</apex:outputPanel> -->
                   
            </apex:pageBlock>
            
        </apex:outputPanel>
    </apex:form>
</apex:page>