                            <apex:inputText styleClass="inputField" html-readonly="true" value="{!dateofbirth}" id="myDateField"/>
                            <div></div>
                            <span class="hidden" id="dateField">Please provide your date of birth.</span>
                        </div>
                        <div class="settings">
                            <label style="text-align: right; font-size: 13px; padding-right: 12px;">Email</label>
                            <apex:inputText styleClass="inputField" value="{!Email}" id="email"/>
                            <div></div>
                            <span class="hidden" id="emailId">Please provide your email.</span>
                        </div>
                        <div class="settings">
                            <label style="text-align: right; font-size: 13px; padding-right: 12px;">Mobile Phone</label>
                            <apex:inputText styleClass="inputField" value="{!CellPhone}"  id="PrimaryphoneNumber2"/>
                            <div></div>
                            <span class="hidden" id="mobileNo">Please provide your mobile number.</span>
                        </div>
                    <!--</div>-->
                    
                    <div class="check-note1" style="font-size: 11px;">
                        <apex:inputCheckbox value="{!consent}" style="margin-top:0;" label="I consent to the use of this information for marketing purposes and offers from Canaccede*."/>I consent to the use of this information for marketing purposes and offers from Canaccede*.
                    </div>
                    
                    
                    <div style="text-align: center;"> 
                        <apex:outputPanel id="dataValidationPanel">
                            <script>
                            function checkRedirect(){
                                var invalidData = '{!InvalidData}';
                                if(invalidData == 'false'){
                                    redirectToSite();
                                }
                            }
                            </script>
                        </apex:outputPanel>
                        <input type="Button" value="Submit" onclick="validateForm();"
                               style="background:#5EB835;color:#FFF;padding: 6px 24px;line-height: 16px;text-align: center;font-weight: bold;border: 1px solid #5EB835; margin-bottom: 15px; cursor: pointer;" class="btnSubmit"
                               target="_blank"/><br/>
                        <!--<apex:commandButton id="submitButton" onclick="validateForm();"
                                            title="Submit" value="Submit"
                                            style="background:#5EB835;color:#FFF;padding: 6px 24px;line-height: 16px;text-align: center;font-weight: bold;border: 1px solid #5EB835; margin-bottom: 15px;" styleClass="btnSubmit"/>-->
                        <h2 style="font-size: 11px; width: 77%; margin: 0 auto;"><i>
                        By clicking this link, you are leaving the Canaccede site and going to the Fidem website. Canaccede 
                        does not offer credit cards and is not responsible for the privacy or other compliance matters of Fidem.
                        </i></h2>
                        <br/>
                        <!--<h2 style="font-size: 11px; width: 50%; margin: 0 auto;"><
                            
                            <strong>As part of the application process and to verify your information, 
                                please go to your email to click the link we sent you.</strong>
                        </h2> -->
                        
                    </div>
                    
                    <apex:actionFunction name="nextProcessingFunction" action="{!nextProcessing}"
                                         oncomplete="checkRedirect();" rerender="stepZeroPageMessagespreprocessing,submitButton,dataValidationPanel" />
                    
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 20px;">
                        <!--<small style="width: 78%; font-size: 10px;">Mastercard Brand Mark are registered trademarks of 
                        Mastercard International Incorporated. This card is issued by Peoples Trust Company under licence 
