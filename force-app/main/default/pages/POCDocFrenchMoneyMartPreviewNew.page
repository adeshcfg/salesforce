<apex:page showHeader="false" controller="POCDocController" id="page">
    <html class="ArialUnicodeMSFont">
        <head>
            <apex:slds />
            <style>
                .ArialUnicodeMSFont {
                    font-family: "Arial";
                }
                .my-checkbox {
                    width: 1rem;
                    height: 1rem;
                    display: inline-block;
                    vertical-align: middle;
                    border: 1px solid #d8dde6;
                    border-radius: 0.125rem;
                    background: #fff;
                    transition:
                        border 0.1s linear,
                        background-color 0.1s linear;
                }
                .pageSeperator {
                    width: 112%;
                    background-color: #d8edff;
                    height: 10px;
                    margin-left: -6%;
                }
                .slds-scope h1,
                .slds-scope h2,
                .slds-scope h3,
                .slds-scope h4,
                .slds-scope h5,
                .slds-scope h6,
                .slds-scope td,
                .slds-scope th {
                    font-family: "Arial";
                }
                .slds-scope {
                    color: #000;
                }
            </style>
            <script>
                function target() {
                    var element = document.getElementById("target");
                    /*var elementAmend = document.getElementById("amendPOCmessage");
                   unfade(elementAmend);*/
                    var checkVal = document.getElementById("page:form:hiddenCheck").value;
                    if (checkVal == "true") {
                        element = document.getElementById("exceptionInPdf");
                        unfade(element);
                        return false;
                    }

                    unfade(element);

                    setTimeout(function () {
                        closeWindow();
                    }, 5000);
                }

                function closeWindow() {
                    window.close();
                }

                function unfade(element) {
                    var op = 0.1; // initial opacity
                    element.style.display = "block";
                    var timer = setInterval(function () {
                        if (op >= 1) {
                            clearInterval(timer);
                        }
                        element.style.opacity = op;
                        element.style.filter = "alpha(opacity=" + op * 100 + ")";
                        op += op * 0.1;
                    }, 0);
                }
                window.onload = function () {
                    //setLanguage();
                    if ("{!isAnyException}" == "true") {
                        var element = document.getElementById("exception");
                        unfade(element);
                    }
                };
            </script>
        </head>
        <apex:outputPanel id="notifier">
            <div class="slds-notify_container success-notifier slds-hide" id="exception">
                <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert" style="font-family: Arial !important">
                    <span class="slds-assistive-text-override"
                        >Sorry, there is a problem generating this proof of claim package; please contact the System Administrator for more information and
                        resolution</span
                    >
                </div>
            </div>
            <div class="slds-notify_container success-notifier slds-hide" id="exceptionInPdf">
                <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert" style="font-family: Arial !important">
                    <span class="slds-assistive-text-override"
                        >There was an error generating the proof of claim package; please contact the System Administrator for more information and
                        resolution</span
                    >
                </div>
            </div>
        </apex:outputPanel>
        <apex:outputPanel rendered="{!amendedPOCcheck}">
            <div class="slds-notify_container success-notifier" id="amendPOCmessage">
                <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert" style="font-family: Arial !important">
                    <span class="slds-assistive-text-override">Please Check Amended Claim checkbox to generate amended POC.</span>
                </div>
            </div>
        </apex:outputPanel>
        <apex:form styleClass="ArialUnicodeMSFont" id="form">
            <apex:inputHidden value="{!isAnyException}" id="hiddenCheck" />
            <apex:outputPanel id="notifier">
                <div class="slds-notify_container success-notifier slds-hide" id="target">
                    <div
                        class="slds-notify slds-notify--alert slds-theme--success slds-theme--alert-texture"
                        role="alert"
                        style="font-family: Arial !important"
                    >
                        <span class="slds-assistive-text-override"
                            >The proof of claim package has been successfully created and attached to the Insolvency Account</span
                        >
                    </div>
                </div>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!pocDocError <> null}">
                <div class="slds-notify_container">
                    <div class="slds-notify slds-notify--alert slds-theme--error slds-theme--alert-texture" role="alert" style="font-family: Arial !important">
                        <h2>{!pocDocError}<br /></h2>
                        <br />
                    </div>
                </div>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!IF((insolvAcc.Insolvency_Status__c == 'PoC Details Provided' && insolvAcc.Proof_of_Claim_Required__c && pocDocError == null), true, false)}"
            >
                <apex:ActionStatus id="spinner">
                    <apex:facet name="start">
                        <div class="slds-spinner_container">
                            <div role="status" class="slds-spinner slds-spinner_medium slds-spinner_brand">
                                <span class="slds-assistive-text">Loading</span>
                                <div class="slds-spinner__dot-a"></div>
                                <div class="slds-spinner__dot-b"></div>
                            </div>
                        </div>
                    </apex:facet>
                </apex:ActionStatus>
                <apex:ActionFunction name="changeLanguage" action="{!changeLanguage}" reRender="form" status="spinner">
                    <apex:param name="firstParam" assignTo="{!pageName}" value="Money Mart" />
                </apex:ActionFunction>
                <apex:ActionFunction name="setLanguage" reRender="none" status="none">
                    <apex:param name="secondParam" assignTo="{!language}" value="fr" />
                </apex:ActionFunction>
                <body class="slds-scope" style="width: 700px; margin: auto; background: #d8edff; padding-top: 20px">
