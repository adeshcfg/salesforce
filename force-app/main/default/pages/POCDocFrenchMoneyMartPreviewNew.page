                                oncomplete="target()"
                                status="spinner"
                                reRender="hiddenCheck,amendPOCmessage"
                                rendered="{!!isAnyException}"
                            >
                                <apex:param name="language" assignTo="{!language}" value="fr" />
                            </apex:commandButton>
                            <input
                                type="button"
