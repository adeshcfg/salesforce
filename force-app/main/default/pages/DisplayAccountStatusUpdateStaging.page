          <apex:define name="content"> 
            <apex:outputPanel rendered="{!!listProductStagingWrapper.Empty}" id="panel2">
                <apex:outputPanel >
                    <div style = "font-weight:bold;font-size:large">
                        Product Staging Records to verify :
                        
                    </div>
                    <apex:outputPanel title="" id="pbs" >
                        <div class="page_navigation"></div>
                        
                        <apex:datatable value="{!listProductStagingWrapper}" var="account" id="pbId">
                            <!--<apex:repeat value="{!contactinfowrp}" var="account">-->
                            <apex:column headerValue="Action" >
                                <apex:facet name="header">
                                    <!--apex:inputCheckbox onclick="selectAllCheckboxes(this,'inputId')">-->
                                    <apex:inputCheckbox selected="{!isSelected}">
                                        <apex:actionSupport event="onchange" action="{!selectAll}" reRender="pbId,panel2"/>
                                    </apex:inputCheckbox>
                                </apex:facet>
                                <apex:inputCheckbox value="{!account.selected}"  disabled="{!account.disabled}" >
                                </apex:inputCheckbox>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"><apex:outputText value="Product"/></apex:facet>
                                <apex:outputLink value="/{!account.accStaging.Product_ID__c}" target="_blank">
                                    {!account.accStaging.Name__c}
                                </apex:outputLink>
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header">Status Code</apex:facet>
                                
                                <!-- changed -->
                                <apex:outputText value="{!account.accStaging.Placement_Status_Code__c}"></apex:outputText>
                                
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header"><apex:outputText value="Status Changed Date"/></apex:facet>
                                <!-- changed -->
                                <apex:outputText value="{!account.accStaging.Status_Changed_Date_Text__c}"/>
                                
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header">Comment</apex:facet>
                                <apex:outputText value="{!account.accStaging.Comment__c}" escape="false"></apex:outputText>
                            </apex:column> 
                            <apex:column style="width:14%;vertical-align:baseline">
                                <apex:facet name="header">Expected Result</apex:facet>
                                <!--apex:outputText value="{!account.accStaging.Expected_Value__c}" escape="false"></apex:outputText-->
                            </apex:column>
                            <apex:column >
                                <apex:facet name="header">Status</apex:facet>
                                <!-- changed -->
                                <apex:outputText value="{!account.accStaging.Status__c}">
                                </apex:outputText>

                            </apex:column>
                            <!--</apex:repeat>--> 
                        </apex:datatable>
                        <apex:actionStatus id="status">
                            <apex:facet name="start">
                                <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.75; z-index: 1000; background-color: black;">
                                    &nbsp;
                                </div>
                                <div style="position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 30% 50%">
                                    <img src="http://upload.wikimedia.org/wikipedia/commons/e/ed/Cursor_Windows_Vista.gif" />
                                </div>
                            </apex:facet>
                        </apex:actionStatus>
                        <apex:actionFunction action="{!Save}" name="InsertRecord_JS" Rerender="panel1, panel2, status, form"
                                             status="status" oncomplete="window.location.reload();"/><!-- oncomplete="location.reload()"/>
                        <apex:actionFunction action="{!postDocumentAPI}" name="CallWebService_JS" status="status"
                                             reRender="panel1, panel2, status, form"/>-->
                        <div class="page_navigation"></div>
                        <div style = "Margin-left:10%;padding-top: 1%;">
                            <!--hello{!!showButton}
                            hello1{!showButton}-->

                            <apex:commandButton onclick="InsertRecord_JS();return false;"
                                                value="Process Records" id="theButtonn" 
                                                styleclass="slds-button slds-button_neutral" 
                                                style="margin-left: 45%;"
                                                disabled="{!!showButton}"/>
                        </div>
                    </apex:outputPanel>
                </apex:outputPanel>
                <apex:outputPanel style="text-align:center;" layout="block">
                    <apex:commandButton value="First" reRender="pbId,panel2,pbId1" action="{!first}" disabled="{!NOT(hasPrevious)}" status="paginationStatus"/>
                    <apex:commandButton value="Previous" rerender="pbId,panel2" action="{!previous}" disabled="{!NOT(hasPrevious)}" status="paginationStatus"/>&nbsp;Page {!pageNumber} of {!totalPages}&nbsp;
                    <apex:commandButton value="Next" rerender="pbId,panel2,pbId1" action="{!next}" disabled="{!NOT(hasNext)}" status="paginationStatus"/>
                    <apex:commandButton value="Last" rerender="pbId,panel2,pbId1" action="{!last}" disabled="{!NOT(hasNext)}" status="paginationStatus"/>
                    <apex:actionStatus id="paginationStatus">
                        <apex:facet name="start">
                            Please wait...<img src="/img/loading32.gif" style="width: 18px;"/>
                        </apex:facet>
                    </apex:actionStatus>
                </apex:outputPanel>
                
            </apex:outputPanel>
            <apex:outputPanel rendered="{!displayPanel}" id="panel1" style="color: #4f9241;
                                                                            font-weight: 500;
                                                                            font-size: 13px;"> 
                Records Process Complete! <br/>
                Please check
                <apex:outputlink value="/{!workAssignmentId}"> Work Assignment </apex:outputlink>&nbsp;record
            </apex:outputPanel>
        </apex:define>
    </apex:form>
</apex:page>