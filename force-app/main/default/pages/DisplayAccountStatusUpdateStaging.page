<apex:page controller="DisplayAccStatusUpdateStagingController" showheader="true" standardStyleSheets="false" 
           sidebar="false" cache="false" docType="html-5.0" >
    <apex:slds />
        <style type="text/css">
            table{
            width: 100%;
            background-color: white;
            border:1px solid black;
            padding: 5px;
            }
            
            tr{
            text-align: left;
            padding: 5px;
            }
            
            td{
            padding: 5px!important;
            
            }
            .first h3{
            background-color: #0CA1CF;
            padding: 5px 3px;
            }
            
            .page_navigation{
            font-family: tahoma;
            font-size: 11px;
            float: left;
            
            }
            
            .page_navigation a{
            text-decoration: none;
            padding: 3px 5px;
            margin: 0 2px;
            background-color: white;
            color: #28ADD9;
            display: block;
            float: left;
            text-align: center;
            border-color:#28ADD9;
            }
            
            .page_navigation .active_page{
            background-color: white;
            color: black;
            }
            
            .demo2{
            margin: 10px 5px;
            background-color: #00064F;
            overflow:auto;
            text-align: center
            }
            
            .title{
            font-family: Georgia;
            font-size: 36px;
            font-style: italic;
            color: white;
            padding: 10px;
            }
            
            .head{
            font-family: Tahoma;
            font-size:20px;
            color: orange;
            padding: 5px;
            overflow: auto;
            
            }
            thead{
            border: 1px solid;
            text-align:center;
            }
            .th{
            text-align:center;
            }
            .body {
            
            
            }
            
            .content {
            width: 90%;
            margin: 0px auto;
            overflow: auto;
            }
            
            .item{
            color: black;
            font-family: Georgia;
            font-size: 16px;
            padding: 10px;
            display: block;
            
            }
            
            .block{
            display:block;
            }
            
            .panel {
            width: 40%;
            float: left;
            padding: 0 30px;
            
            }
            
            .demo2 .page_navigation a{
            background-color: orange;
            color: black;
            }
            
            .demo2 .page_navigation .active_page{
            background-color: transparent;
            color: white;
            }
            
            #theid{
            align-content: center;
            text-align: center;
            margin-left: 32%;
            margin-top: 3%;
            }       
            
        </style>
    <apex:form id="form">
        
        <!--apex:includeScript value="{!$Resource.EFTJQuery}"/>     
<apex:includeScript value="{!$Resource.Paginate}"/-->       
