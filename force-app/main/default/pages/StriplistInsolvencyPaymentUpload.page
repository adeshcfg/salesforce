                             rerender="outputData,form,page1, paymentBtns,pageStatus"
                             oncomplete="disableInput();">
            <apex:param assignTo="{!outputJSON}" name="excelToJSONServiceResponse" value=""/>
            <apex:param assignTo="{!fileUploadStatus}" name="uploadstatus" value=""/>
        </apex:actionFunction> -->
        <apex:actionFunction action="{!processExcelFile}" name="processExcelFile"
                             rerender="outputData,form,page1, paymentBtns,pageStatus"
                             oncomplete="disableInput();">
            <apex:param assignTo="{!excelFile}" name="excelFile" value=""/>
        </apex:actionFunction>
    </apex:outputPanel>
</apex:form>
</apex:page>