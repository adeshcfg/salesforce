            }
            function callUploadFile(){
                
                // Valdiating whether document type is choosen or not
                if(document.getElementById('pg:form:documentType').value == ''){
                    $('#descriptionError').removeClass('slds-hide');
                    $('#fileBox').value = null;
                    return false;
                }else{
                    $('#descriptionError').addClass('slds-hide');
                }

                if(window.File && window.FileList) {
                    files = [];
                    files = $('#fileBox').prop("files")
                    fileCounter = 0;
                    $('.uploadBoxes').empty();
                    prepareUpload(files);               
                    startUploading(); 
