            /*alert("Hi");*/
            var homeOwnerFieldObj = $("[id*='homeOwnerField']:checked");   
            if (homeOwnerFieldObj != undefined && homeOwnerFieldObj.val() == "Yes") {
                $("#rentQuestion").hide();
                $("#mortgageQuestion").show();
