                var errorReturned = $("[id*='stepZeroPageMessagespreprocessing']").children().length > 0;
                if (errorReturned == false) {
                    // Transition to Step Two
                    $("#steppreprocessing").addClass("hidden");
                    $("#stepZero").removeClass("hidden");
                    
                    //pushHit('/application-form/step0', 'Application Form Step 0');
                }
                if (errorReturned == true) {
                    return false;
                }
                // Re-enable submit button -- whether errors or not
                $("[id*='stepPreprocessingContinue']").removeAttr("disabled");
                // $("#myModal").addClass("hidden");
                // if (event.target == modal) {
                modal.style.display = "none";
                // }
                myBtn.style.display = "none";
                adjustHeight();
            }
            
            
            
