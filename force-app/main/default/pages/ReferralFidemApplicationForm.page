        $("input[id*='permanentRentOrOwnField']").change( function() {
            var permanentRentOrOwnObj = $("[id*='permanentRentOrOwnField']:checked");   
            if (permanentRentOrOwnObj != undefined && permanentRentOrOwnObj.val() == "Own Property") {
