    $(document).ready( function () {
        
        // Toggle code entry fields if "offer code avail" answer changes                   
        $("input[id*='offerCodeAvailRadio']").change( function() {
            var offerCodeValue= $("[id*='offerCodeAvailRadio']:checked");
