                $("#mortgageQuestion").show();
                $("#mortgageWithQuestion").show();
            } 
            else if (permanentRentOrOwnObj != undefined && permanentRentOrOwnObj.val() == "Rent") {
                $("#mortgageQuestion").hide();
                $("#mortgageWithQuestion").hide();
