               </div>
                <br/><br/>
               <div class="pageSeperator" style="display : {!IF(insolvAcc.Claim_Type__c == "Unsecured", 'block;', 'none;')}">
                        </div>
                        </apex:outputPanel> -->
                   <apex:outputPanel rendered="{!form37}" >
                     <div style="font-size: 13px; margin:auto; padding-top:20px; line-height: 17px; width:90%;">
                        <div style="line-height: 17px;padding-left: 15px;">
                           <div>
                              District of: {!insolvAcc.Insolvency__r.Court_District_Name__c}<br/>
                              Division No: {!insolvAcc.Insolvency__r.Court_Division_Number__c}<br/>
                              Court No: {!insolvAcc.Insolvency__r.Debtor_1_Court_Number__c}{!IF(insolvAcc.Insolvency__r.Debtor_2_Court_Number__c != null,';','')}&nbsp;{!insolvAcc.Insolvency__r.Debtor_2_Court_Number__c}<br/>
