<apex:page standardController="Unallocated_Payment__c" extensions="ProcessingUnallocatedProductController" sidebar="false" showHeader="false" id="page">
    <Script>
            function closeWindow(){
                setTimeout(function(){
                  window.opener.location='/{!unAloccPay.Id }';
                  window.close();
                }, 3000);
            }
            function disablethis(){
                document.getElementById('page:fm:pb:pbtn:savebtn').disabled = true;
            }
    </script>
      <apex:form id="fm">
      <apex:pageMessages id="msg"></apex:pageMessages>
      <apex:pageBlock title="Choose CCS Account" rendered="{!!unAloccPay.Allocated__c && !unAloccPay.Is_Payment_Remitted__c}" id="pb">
          <apex:pageBlockButtons location="top" id="pbtn">
              <apex:commandButton id="savebtn" Value="Save" action="{!save}" onclick="disablethis();" oncomplete="closeWindow();" reRender="msg"/>
          </apex:pageBlockButtons>
          
          <apex:pageblockSection >
              <apex:inputField label="CCS Account" value="{!insolvPay.CCS_Account__c}"/>
          </apex:pageblockSection>
        </apex:pageBlock>
      </apex:form>
  
</apex:page>