<apex:page standardController="Product__c" extensions="BulkBuybackPutbackEligibleController" recordSetVar="Product"  showheader="true" standardStyleSheets="false" 
           sidebar="false" cache="false" docType="html-5.0" >
    <apex:form id="fms">
    <apex:slds />
    <style type="text/css">
       
