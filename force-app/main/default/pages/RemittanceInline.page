<apex:page standardController="Insolvency_Payment__c" extensions="RemittanceInlineController" showHeader="false" sidebar="false">
	
	<apex:pageBlock >
         <apex:pageBlockTable value="{!remAttachWrapList}" var="remAttachWrap" columns="3">
             
             <apex:column headerValue="NAME">
                 <a href="#" onclick='window.open("../servlet/servlet.FileDownload?file={!remAttachWrap.attach.Id}", "_blank", "toolbar=yes,scrollbars=yes,resizable=yes,top=250,left=400,width=700,height=700");'>{!remAttachWrap.attach.Name}</a>
             </apex:column>
             
             <apex:column >
                 <apex:facet name="header">
                     <apex:outputLabel >CREATED DATE</apex:outputLabel>
                 </apex:facet>
                 <apex:outputText value="{0, date, MMMM d',' yyyy hh:mm a}">
                     <apex:param value="{!remAttachWrap.attach.CreatedDate}" /> 
                 </apex:outputText>
             </apex:column>
             
             <apex:column >
                 <apex:facet name="header">
                     <apex:outputLabel >LAST MODIFIED DATE</apex:outputLabel>
                 </apex:facet>
                 <apex:outputText value="{0, date, MMMM d',' yyyy hh:mm a}">
                     <apex:param value="{!remAttachWrap.attach.LastModifiedDate}" /> 
                 </apex:outputText>
             </apex:column>
             
         </apex:pageBlockTable>
    </apex:pageBlock>
</apex:page>