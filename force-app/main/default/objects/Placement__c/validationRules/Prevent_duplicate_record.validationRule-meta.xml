<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_duplicate_record</fullName>
    <active>true</active>
    <description>Restrict user to create duplicate record</description>
    <errorConditionFormula>IF( UPPER(Name) == UPPER(VLOOKUP( $ObjectType.Placement__c.Fields.Name, $ObjectType.Placement__c.Fields.Name, Name)),true , false)</errorConditionFormula>
    <errorMessage>&quot;Duplicate Record&quot; A record with this name already exists</errorMessage>
</ValidationRule>
