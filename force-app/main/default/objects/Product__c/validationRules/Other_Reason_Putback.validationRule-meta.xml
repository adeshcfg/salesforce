<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Other_Reason_Putback</fullName>
    <active>true</active>
    <description>When Buyback/Putback Reason is set to Other then Other reason should be mandatory</description>
    <errorConditionFormula>$Setup.Disable_Metadata_Settings__c.Disable_Product_Validation_WF__c == false &amp;&amp;
ISPICKVAL(Buyback_Putback_Reason__c, &quot;Other&quot;) &amp;&amp;  ISBLANK(Other_Reason__c)</errorConditionFormula>
    <errorDisplayField>Other_Reason__c</errorDisplayField>
    <errorMessage>Please Enter Other Reason</errorMessage>
</ValidationRule>
