<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Putback_Reason</fullName>
    <active>true</active>
    <description>When purchase status is set to Buyback/Putback Rejected then Rejection reason should be mandatory</description>
    <errorConditionFormula>$Setup.Disable_Metadata_Settings__c.Disable_Product_Validation_WF__c == false &amp;&amp;
ISPICKVAL(Purchase_Status__c, &quot;Buyback/Putback Rejected&quot;) &amp;&amp;  ISBLANK(Rejection_Reason__c)</errorConditionFormula>
    <errorDisplayField>Rejection_Reason__c</errorDisplayField>
    <errorMessage>Please Enter Rejection Reason</errorMessage>
</ValidationRule>
