<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Putback_Reason</fullName>
    <active>true</active>
    <description>When purchase status is set to putback then Putback reason should be mandatory</description>
    <errorConditionFormula>ISPICKVAL(Purchase_Status__c, &quot;Putback&quot;) &amp;&amp;  ISBLANK( Putback_Reason__c )</errorConditionFormula>
    <errorDisplayField>Accepted_Donation_Rate__c</errorDisplayField>
    <errorMessage>Please Enter Putback Reason</errorMessage>
</ValidationRule>
