<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Value_tier_Validation</fullName>
    <active>true</active>
    <description>The value tier supports only alphabetic and special characters only.</description>
    <errorConditionFormula>AND(ISCHANGED(Value_Tier__c),
OR(
if(NOT(REGEX(Text(Value_Tier__c), &quot;^[a-zA-Z!@#$&amp;?!*%()\\-`.+,/\&quot;]*$&quot;)),true,false),
if((REGEX(Text(Value_Tier__c), &quot;^[!@#$&amp;?!*%()\\-`.+,/\&quot;]*$&quot;)),true,false),
if(NOT(REGEX(Text(Value_Tier__c),&quot;[a-zA-Z]{1}.*&quot;)),true,false)
)
)</errorConditionFormula>
    <errorDisplayField>Value_Tier__c</errorDisplayField>
    <errorMessage>Invalid Value tier</errorMessage>
</ValidationRule>
