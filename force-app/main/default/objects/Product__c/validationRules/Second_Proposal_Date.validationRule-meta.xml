<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Second_Proposal_Date</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
AND(ISCHANGED(Second_Proposal_Date__c),Second_Proposal_Date__c&gt; TODAY()),

AND(OR(ISCHANGED(Second_Proposal_Date__c),ISCHANGED(Initial_Proposal_Date__c)),
Initial_Proposal_Date__c&gt; Second_Proposal_Date__c)

)</errorConditionFormula>
    <errorDisplayField>Second_Proposal_Date__c</errorDisplayField>
    <errorMessage>The Second Proposal Date cannot be in future and should be greater than Initial Proposal Date</errorMessage>
</ValidationRule>
