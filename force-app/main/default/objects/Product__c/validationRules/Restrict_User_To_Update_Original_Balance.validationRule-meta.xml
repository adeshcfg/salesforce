<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_User_To_Update_Original_Balance</fullName>
    <active>true</active>
    <errorConditionFormula>AND(

   ISCHANGED(Original_Balance__c),

   NOT ISBLANK(PRIORVALUE(Original_Balance__c))

)</errorConditionFormula>
    <errorDisplayField>Accepted_Donation_Rate__c</errorDisplayField>
    <errorMessage>Original Balance Can Not Be Modified</errorMessage>
</ValidationRule>
