<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Initial_Proposal_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Initial_Proposal_Date__c),Initial_Proposal_Date__c&gt; TODAY())</errorConditionFormula>
    <errorDisplayField>Initial_Proposal_Date__c</errorDisplayField>
    <errorMessage>Initial Proposal Date should not be future date</errorMessage>
</ValidationRule>
