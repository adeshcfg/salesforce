<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CCS_Counter_Amount</fullName>
    <active>true</active>
    <description>Please enter the Counter Amount</description>
    <errorConditionFormula>AND(ISPICKVAL(Proposal_Status__c , &apos;Counter&apos;) ,
ISBLANK(Counter__c))</errorConditionFormula>
    <errorDisplayField>Accepted_Donation_Rate__c</errorDisplayField>
    <errorMessage>Please enter the Counter Amount</errorMessage>
</ValidationRule>
