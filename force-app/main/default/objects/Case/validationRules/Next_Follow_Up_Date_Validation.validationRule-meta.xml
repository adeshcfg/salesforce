<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Next_Follow_Up_Date_Validation</fullName>
    <active>true</active>
    <description>Next Follow Up Date can&apos;t be in past</description>
    <errorConditionFormula>AND($User.LastName &lt;&gt; $Label.DataArchiverUser,
(OR(ISNEW(), ISCHANGED(Next_Follow_Up_Date__c)))
,
(AND(NOT(ISNULL(Next_Follow_Up_Date__c)), Next_Follow_Up_Date__c &lt; TODAY()))
)</errorConditionFormula>
    <errorDisplayField>Next_Follow_Up_Date__c</errorDisplayField>
    <errorMessage>Next Follow Up Date can&apos;t be in past</errorMessage>
</ValidationRule>
