<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Legal_Sub_Status_Required</fullName>
    <active>true</active>
    <description>If Legal Status is populated, Legal Substatus should become mandatory</description>
    <errorConditionFormula>AND(
    ISPICKVAL(Legal_Sub_Status__c,&apos;&apos;),
    NOT(ISPICKVAL(Legal_Status__c, &apos;&apos;))
)</errorConditionFormula>
    <errorDisplayField>Legal_Sub_Status__c</errorDisplayField>
    <errorMessage>Please select Legal Sub Status</errorMessage>
</ValidationRule>
