<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Interest_five_not_required</fullName>
    <active>false</active>
    <description>Interest-5 is not required if Balance-5 is empty</description>
    <errorConditionFormula>AND(
    ISBLANK( Balance_five__c ),
    NOT(ISBLANK( Interest_Rate_five__c ))
)</errorConditionFormula>
    <errorDisplayField>Interest_Rate_five__c</errorDisplayField>
    <errorMessage>Interest-5 is not required if Balance-5 is empty</errorMessage>
</ValidationRule>
