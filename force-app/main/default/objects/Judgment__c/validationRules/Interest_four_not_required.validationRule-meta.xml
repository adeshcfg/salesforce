<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Interest_four_not_required</fullName>
    <active>false</active>
    <description>Interest-4 is not required if Balance-4 is empty</description>
    <errorConditionFormula>AND(
    ISBLANK( Balance_four__c ),
    NOT(ISBLANK( Interest_Rate_four__c ))
)</errorConditionFormula>
    <errorDisplayField>Interest_Rate_four__c</errorDisplayField>
    <errorMessage>Interest-4 is not required if Balance-4 is empty</errorMessage>
</ValidationRule>
