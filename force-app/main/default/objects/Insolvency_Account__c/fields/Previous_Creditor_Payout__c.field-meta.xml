<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Previous_Creditor_Payout__c</fullName>
    <externalId>false</externalId>
    <formula>CASE(Insolvency__r.Insolvency_Type__c,
&apos;Bankruptcy&apos;,((Claim_Amount__c*Purchase_Factor__c) * (((22 * Value(TEXT(Insolvency__r.Expected_Discharge_Month__c))) / 12) / 100)),
((
(
Insolvency__r.Previous_Offer_Amount__c
)
 - Insolvency__r.Previous_Trustee_Fees__c
)
*
(
1 - $Setup.Trustee_Fees__c.Superintendant_Variable_Fee_Rate__c
))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Previous Creditor Payout</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
