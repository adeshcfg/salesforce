<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Mandatory_On_Reason_for_No_Poc_Required</fullName>
    <active>true</active>
    <description>If other option is selected in Reason For No Poc required , This field is mandatory</description>
    <errorConditionFormula>AND($User.LastName &lt;&gt; $Label.DataArchiverUser,
OR(ISCHANGED(Reason_for_No_PoC_Required_Dropdown__c), ISNEW()),
ISPICKVAL(Reason_for_No_PoC_Required_Dropdown__c,&apos;Other&apos;),
ISBLANK( Reason_for_No_PoC_Required__c
))</errorConditionFormula>
    <errorDisplayField>Reason_for_No_PoC_Required__c</errorDisplayField>
    <errorMessage>Please enter the Reason</errorMessage>
</ValidationRule>
