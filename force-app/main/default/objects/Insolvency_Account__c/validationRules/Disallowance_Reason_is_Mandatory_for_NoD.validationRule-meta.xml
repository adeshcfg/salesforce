<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Disallowance_Reason_is_Mandatory_for_NoD</fullName>
    <active>true</active>
    <description>Disallowance Reason is mandatory for Date NoD Received</description>
    <errorConditionFormula>AND(
OR(OR(ISCHANGED(Date_NOD_received__c),ISCHANGED(Disallowance_Reasons__c)),ISNEW()),
ISPICKVAL(Disallowance_Reasons__c,&apos;&apos;),
NOT(ISNULL( Date_NOD_received__c))
)</errorConditionFormula>
    <errorDisplayField>Disallowance_Reasons__c</errorDisplayField>
    <errorMessage>Disallowance Reason is mandatory for Date NoD Received</errorMessage>
</ValidationRule>
