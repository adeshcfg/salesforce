<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Claim_Amount_Required</fullName>
    <active>true</active>
    <description>Claim_amount_required when select/update No_POC_Required</description>
    <errorConditionFormula>IF( OR( ISPICKVAL( Reason_for_No_PoC_Required_Dropdown__c, &apos; &apos; ), ISBLANK( Claim_Amount__c )), true, false )</errorConditionFormula>
    <errorMessage>Please Enter the Claim Amount</errorMessage>
</ValidationRule>
