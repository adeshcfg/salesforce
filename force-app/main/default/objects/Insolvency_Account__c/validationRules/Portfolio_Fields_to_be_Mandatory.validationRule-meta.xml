<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Portfolio_Fields_to_be_Mandatory</fullName>
    <active>false</active>
    <errorConditionFormula>AND(Created_By_Doc_Parser__c == FALSE,
RecordType.DeveloperName =&apos;Canaccede_Insolvency_Account&apos;  
,OR(ISBLANK(TEXT(Investment_Group__c)),
ISBLANK(Portfolio_Name_Lookup__c),
ISBLANK(TEXT(Portfolio_Group_Name__c)) 
))</errorConditionFormula>
    <errorMessage>Investment Group Name, Portfolio Group Name &amp; Portfolio Name are mandatory fields to be entered.</errorMessage>
</ValidationRule>
