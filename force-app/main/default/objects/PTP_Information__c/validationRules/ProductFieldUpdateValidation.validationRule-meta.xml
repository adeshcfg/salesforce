<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ProductFieldUpdateValidation</fullName>
    <active>true</active>
    <description>This rule allows only system Administrators to update product field on PTP record</description>
    <errorConditionFormula>IF(OR(ISNEW(),  $Profile.Name == &apos;System Administrator&apos;), false,
 ISCHANGED( Product__c ) 
)</errorConditionFormula>
    <errorDisplayField>Product__c</errorDisplayField>
    <errorMessage>You can&apos;t change the Product assigned</errorMessage>
</ValidationRule>
