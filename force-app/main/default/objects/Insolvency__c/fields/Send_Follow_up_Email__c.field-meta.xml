<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Send_Follow_up_Email__c</fullName>
    <description>This formula field turns TRUE once the Insolvency Date equals to Date prior to the X Months mentioned in Follow_Up_Prior_Months__c from Today.</description>
    <externalId>false</externalId>
    <formula>If(Insolvency_Date__c = ADDMONTHS(TODAY(), -Trustee__r.Follow_Up_Prior_Months__c), TRUE, FALSE)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Send Follow-up Email</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
