<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Estate2</fullName>
    <active>false</active>
    <errorConditionFormula>And (NOT(ISBLANK( Debtor_2_Estate_Number__c)),NOT( REGEX( Debtor_2_Estate_Number__c, &quot;(((\\d{2}-){1}\\d{7}))&quot;)))</errorConditionFormula>
    <errorDisplayField>Debtor_2_Estate_Number__c</errorDisplayField>
    <errorMessage>Estate number is invalid, should be in this format xx-xxxxxxx</errorMessage>
</ValidationRule>
