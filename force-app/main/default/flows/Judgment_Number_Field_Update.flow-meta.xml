<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <decisions>
        <description>Judgment Number Field Update</description>
        <name>Judgment_criteria</name>
        <label>Judgment criteria</label>
        <locationX>650</locationX>
        <locationY>378</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Legal_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Legal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Post-Judgment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Legal_Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Vacated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Judgment_Record_Type</targetReference>
            </connector>
            <label>Legal Status</label>
        </rules>
        <rules>
            <name>Defended_Action</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Legal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pre-Judgment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Legal_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Judgment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Legal_Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Defended Action</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Judgment_Defended_Action</targetReference>
            </connector>
            <label>Defended Action</label>
        </rules>
    </decisions>
    <description>Change Page layout to Post-Judgment-Vacated with all fields read-only, Update Defended Action</description>
    <environments>Default</environments>
