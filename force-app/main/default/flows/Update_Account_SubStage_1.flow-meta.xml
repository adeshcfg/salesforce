<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <description>If the opportunity related Account record type is Sales Pipeline - Update Account sub stage with opportunity stage</description>
    <environments>Default</environments>
    <interviewLabel>Update Account SubStage_1 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update Account SubStage_1</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>myRule_1_A1</name>
        <label>Update Account sub stage</label>
        <locationX>497</locationX>
        <locationY>371</locationY>
        <inputAssignments>
            <field>Stage__c</field>
            <value>
                <stringValue>Opportunity</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Stage__c</field>
            <value>
                <elementReference>$Record.StageName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record.Account</inputReference>
    </recordUpdates>
    <start>
        <locationX>373</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>myRule_1_A1</targetReference>
        </connector>
        <filterFormula>AND(
{!$Record.Account.RecordType.DeveloperName} == &apos;Sales_Pipeline&apos;,
OR(
      ISNEW(),
      ISCHANGED({!$Record.StageName} )
     )
)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
