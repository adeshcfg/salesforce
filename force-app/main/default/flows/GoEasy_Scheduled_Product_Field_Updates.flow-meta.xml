<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <environments>Default</environments>
    <formulas>
        <description>Number of months between 2 Date fields</description>
        <name>MonthsDifference</name>
        <dataType>Number</dataType>
        <expression>MONTH({!$Record.Expected_First_disbursement_date__c}) + 12 - MONTH({!$Flow.CurrentDate}) + 12 * (YEAR({!$Record.Expected_First_disbursement_date__c}) - YEAR({!$Flow.CurrentDate}) -1)</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>GoEasy Scheduled Product Field Updates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>GoEasy Scheduled Product Field Updates</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Calculate the number of months between &quot;Expected First disbursement Date&quot; and &quot;Today’s date&quot;</description>
        <name>Update_Months_active_in_Program</name>
        <label>Update Months active in Program</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Expected_First_disbursement_date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Months_active_in_Program__c</field>
            <value>
                <elementReference>MonthsDifference</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Months_active_in_Program</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Record_Type_Name__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>GoEasy_CCS_Account</stringValue>
            </value>
        </filters>
        <object>Product__c</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2023-07-31</startDate>
            <startTime>00:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
