<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Laura and Catricea needs access to Megasys Interaction Tab. But Application Admin do not have access so this permission set will give access to the Megasys Interaction Tab</description>
    <fieldPermissions>
        <editable>true</editable>
        <field>MegaSys_Payments__c.No_Of_Records_Processed__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <hasActivationRequired>false</hasActivationRequired>
    <label>App Admin to Loan Admin</label>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MegaSys_Payments__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <pageAccesses>
        <apexPage>MegasysPaymentCSVRequest</apexPage>
        <enabled>true</enabled>
    </pageAccesses>
    <tabSettings>
        <tab>MegaSys_Payments_CSV</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>MegaSys_Payments__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewAllCustomSettings</name>
    </userPermissions>
</PermissionSet>
