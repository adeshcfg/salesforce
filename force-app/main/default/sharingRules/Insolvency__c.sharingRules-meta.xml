<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <sharingCriteriaRules>
        <fullName>QA_read_only</fullName>
        <accessLevel>Read</accessLevel>
        <label>QA read only</label>
        <sharedTo>
            <group>QA_Insolvency_Group</group>
        </sharedTo>
        <booleanFilter>1 OR 2 OR 3 OR 4</booleanFilter>
        <criteriaItems>
            <field>Client_Identifiers__c</field>
            <operation>contains</operation>
            <value>Scotia Bank</value>
        </criteriaItems>
        <criteriaItems>
            <field>Client_Identifiers__c</field>
            <operation>contains</operation>
            <value>Canaccede</value>
        </criteriaItems>
        <criteriaItems>
            <field>Client_Identifiers__c</field>
            <operation>contains</operation>
            <value>SDA</value>
        </criteriaItems>
        <criteriaItems>
            <field>Client_Identifiers__c</field>
            <operation>contains</operation>
            <value>SPL</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>false</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingCriteriaRules>
        <fullName>Share_Canadian_Tire_Insolvency</fullName>
        <accessLevel>Edit</accessLevel>
        <description>Share Canadian Tire Insolvency</description>
        <label>Share Canadian Tire Insolvency</label>
        <sharedTo>
            <group>Insolvency_Canadian_Tire_Users</group>
        </sharedTo>
        <booleanFilter>1 AND 2</booleanFilter>
        <criteriaItems>
            <field>Client_Identifiers__c</field>
            <operation>contains</operation>
            <value>Canadian Tire</value>
        </criteriaItems>
        <criteriaItems>
            <field>Insolvency_Status__c</field>
            <operation>notEqual</operation>
            <value>Staging</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
