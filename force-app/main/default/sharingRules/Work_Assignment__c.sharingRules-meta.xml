    <sharingCriteriaRules>
        <fullName>Agency_Group_Sharing_Setting</fullName>
        <accessLevel>Edit</accessLevel>
        <description>Share agency records with supervisor.</description>
        <label>Agency Group Sharing Setting</label>
        <sharedTo>
            <group>Agency_Group</group>
        </sharedTo>
        <booleanFilter>1 AND 2 AND 3</booleanFilter>
        <criteriaItems>
            <field>RecordTypeId</field>
            <operation>equals</operation>
            <value>CFG Excel Processing,CFG Media,Agency Excel Processing,Agency Work Assignment,Agency Media,CFG Work Assignment</value>
        </criteriaItems>
        <criteriaItems>
            <field>Placement_Agency_Identifier__c</field>
            <operation>notEqual</operation>
            <value>6</value>
        </criteriaItems>
        <criteriaItems>
            <field>Placement_Agency_Identifier__c</field>
            <operation>notEqual</operation>
            <value>68</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>false</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
