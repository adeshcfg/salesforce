    <sharingCriteriaRules>
        <fullName>Share_Insolvency_Cases_CFG_Users_BS</fullName>
        <accessLevel>Edit</accessLevel>
        <label>Share Insolvency Cases CFG Users BS</label>
        <sharedTo>
            <group>Insolvency_CFG_BS</group>
        </sharedTo>
        <criteriaItems>
            <field>RecordTypeId</field>
            <operation>equals</operation>
            <value>EmailToCase,Insolvency Scotia Community Case,Insolvency SDA Community Case,Remittance,Insolvency Case,Canaccede EmailToCase,Insolvency SPL Community Case</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>false</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
