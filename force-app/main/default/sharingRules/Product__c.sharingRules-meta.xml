        <accessLevel>Edit</accessLevel>
        <description>sharing rule for record with Collection Agency is neither 68 nor 6 &amp; Distressed Account, share with Agency Group</description>
        <label>Agency Group Product Sharing</label>
        <sharedTo>
            <group>Agency_Group</group>
        </sharedTo>
        <criteriaItems>
            <field>Collection_Agency__c</field>
            <operation>notEqual</operation>
            <value>68</value>
