    <sharingCriteriaRules>
        <fullName>QA_Access</fullName>
        <accessLevel>Read</accessLevel>
        <label>QA Access</label>
        <sharedTo>
            <group>QA_Group</group>
        </sharedTo>
        <criteriaItems>
            <field>Client_Identifier__c</field>
            <operation>equals</operation>
            <value>Canaccede,Scotia Bank</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
