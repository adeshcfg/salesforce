        <sharedTo>
            <group>Insolvency_Canadian_Tire_Users</group>
        </sharedTo>
        <booleanFilter>1 AND 2 AND 3 AND 4</booleanFilter>
        <criteriaItems>
            <field>Client_Identifier__c</field>
            <operation>equals</operation>
            <value>Canadian Tire</value>
        </criteriaItems>
        <criteriaItems>
            <field>RecordTypeId</field>
            <operation>equals</operation>
            <value>Canadian Tire Insolvency Account</value>
